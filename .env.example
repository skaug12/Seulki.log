# IMWEB API 인증 정보
# IMWEB 관리자 페이지에서 발급받은 API Key와 Secret을 입력하세요
# 관리자 > 환경설정 > API 연동 메뉴에서 확인 가능합니다

IMWEB_API_KEY=your_api_key_here
IMWEB_API_SECRET=your_api_secret_here

# CLOVA Speech API 인증 정보
# 네이버 클라우드 플랫폼에서 발급받은 Secret Key와 Invoke URL
CLOVA_SPEECH_API_KEY=your_clova_speech_api_key_here
CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt
