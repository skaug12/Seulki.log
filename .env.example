# HFK 시즌레터 생성에 필요한 환경변수

# 구글 캘린더 API 키 (Google Cloud Console에서 발급)
GOOGLE_API_KEY=your_api_key_here

# HFK 캘린더 ID (캘린더 설정 > 캘린더 통합에서 확인)
# 형식: xxxxxxxx@group.calendar.google.com
HFK_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Anthropic API Key (후기 생성용, 이미 설정되어 있다면 생략)
# ANTHROPIC_API_KEY=your_anthropic_api_key
